{
  "name": "peachy-kareoke",
  "version": "2.0.1",
  "private": true,
  "repository": "https://github.com/TZFC/Kareoke",
  "main": "dist/main.js",
  "scripts": {
    "dev": "cross-env npm_config_loglevel=error concurrently \"tsc -p tsconfig.main.json --watch\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "cross-env npm_config_loglevel=error tsc -p tsconfig.main.json && vite build --logLevel error",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.1",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@soundtouchjs/audio-worklet": "^2.1.0",
    "@soundtouchjs/core": "^2.1.0",
    "@spotify/basic-pitch": "^1.0.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@xenova/transformers": "^2.17.2",
    "demucs": "^1.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lrc-kit": "^1.2.1",
    "pitchy": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "soundbank-pitch-shift": "^1.0.3",
    "tone": "^15.1.22"
  },
  "build": {
    "appId": "com.peachykareoke.app",
    "productName": "PeachyKareoke",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "TZFC",
        "repo": "Kareoke"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "node_modules/demucs/**/*"
    ]
  }
}