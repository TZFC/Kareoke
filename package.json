{
  "name": "peachy-kareoke",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--throw-deprecation npm_config_loglevel=error concurrently \"tsc -p tsconfig.main.json --watch\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "cross-env NODE_OPTIONS=--throw-deprecation npm_config_loglevel=error tsc -p tsconfig.main.json && vite build --logLevel error",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.6.2",
    "electron-packager": "^17.1.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.1",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.peachykareoke.app",
    "productName": "PeachyKareoke",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "artifactName": "${productName}-Setup-${version}.exe"
    }
  }
}
